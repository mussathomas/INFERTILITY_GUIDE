# Backend environment variables for Railway deployment
# Copy this to backend/.env and fill in your actual values

# Gemini API Key (get from https://ai.google.dev/)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret Key - change this to a strong random string in production
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database URL - SQLite (auto-created in data/ directory)
DATABASE_URL=sqlite:///./data/app.db

# Knowledge Base Directory
KNOWLEDGE_BASE_DIR=./knowledge_base

# Chroma Vector Store Directory
CHROMA_PERSIST_DIR=./data/chroma

# Gemini Model
GEMINI_MODEL=gemini-2.0-flash

# Token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG Configuration
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5
